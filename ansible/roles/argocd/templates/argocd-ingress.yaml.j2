# Exposes the ArgoCD UI at argocd.{{ domain }} via Traefik.
# argocd-server runs --insecure (plain HTTP); Cloudflare terminates TLS at the edge.
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: argocd-server
  namespace: argocd
spec:
  ingressClassName: traefik
  rules:
    - host: argocd.{{ domain }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: argocd-server
                port:
                  number: 80
