# ============================================================================
#  Secrets only.  Copy to ".env" (gitignored, never committed).
#
#  Everything else — domain, which repo, which tools — lives in
#  gitops/root/values.yaml (committed to the public repo so ArgoCD can read it
#  with no token).
# ============================================================================

# ── Cloudflare API token ──
# Scopes: Account:Cloudflare Tunnel:Edit  +  Zone:DNS:Edit  +  Zone:Zone:Read
CF_API_TOKEN=
CF_ACCOUNT_ID=

# ── VM sizing override (optional) ──
# Blank = auto-compute from the enabled flags in values.yaml (clamp 4-8GB / 4-8 CPU).
VM_MEMORY=
VM_CPUS=
